# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ──────────────────────────────────────────────────────────────────
# Connection string for MongoDB (e.g. mongodb://user:pass@host:port/dbname)
MONGODB_URI=mongodb://127.0.0.1:27017/vivek_portfolio

# ─── Security & Authentication ────────────────────────────────────────────────
# Admin credentials stored in the database on first run
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_to_a_secure_12_character_password

# Secret used to sign session cookies (at least 32 characters recommended)
SESSION_SECRET=your_ultra_secure_session_secret_here

# ─── Frontend Integration ─────────────────────────────────────────────────────
# The URL of your live site for CORS configuration
FRONTEND_URL=http://localhost:5000
